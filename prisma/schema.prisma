generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String     @id @default(uuid())
  name                      String?
  email                     String     @unique
  emailVerified             Boolean    @default(false)
  image                     String?
  role                      String     @default("user")   // 'admin', 'user', etc.
  banned                    Boolean    @default(false)
  banReason                  String?
  banExpires                 DateTime?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @default(now()) @updatedAt

  paystackCustomerId        String?    @unique
  paystackAuthorizationCode String?

  subscriptions             Subscription[]
  sessions                   Session[]
  accounts                   Account[]
  reports                    Report[]
  blogPosts                  Blog[]

  @@map("user")
}

model SubscriptionPlan {
  id                  String       @id @default(uuid())
  code                String       @unique    // e.g. "free", "pro", "enterprise"
  name                String
  paystackPlanCode    String?      // Code used by Paystack for paid plans
  amount              Int?         // in kobo (for paid plans), null or 0 for free
  interval             String      // e.g. "monthly", "yearly"
  features             Json?        // optional JSON field to encode plan limits etc.
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @default(now()) @updatedAt

  subscriptions       Subscription[]

  @@map("subscriptionPlan")
}

model Subscription {
  id                       String      @id @default(uuid())
  status                   String     
  planType                 String?     @default("free")
  paystackSubscriptionId   String?     @unique
  paystackPlanCode         String?
  planId                   String?
  plan                     SubscriptionPlan? @relation(fields: [planId], references: [id])
  planAmount               Int?        // in kobo
  startDate                DateTime    @default(now())
  nextPaymentDate          DateTime?
  cancelledAt              DateTime?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @default(now()) @updatedAt
  userId                   String      @unique
  endDate                  DateTime?
  reference                String?
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, paystackSubscriptionId], name: "user_subscription_unique")
  @@map("subscription")
}

model Report {
  id              String     @id @default(uuid())
  url             String
  performance     Int
  metrics         Json        // JSON object: { fcp, lcp, tbt, cls, si, … }
  recommendations Json       // JSON array / object of recommendation items
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt

  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("report")
}

model Session {
  id            String     @id @default(uuid())
  expiresAt     DateTime
  token         String     @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt
  ipAddress     String?
  userAgent     String?
  impersonatedBy String?

  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String   @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  position              String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  @@map("account")
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  img       String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Team {
  id            String     @id @default(uuid())
  name          String?
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  position      String?
  about         String?
  twitterUrl    String?    @default("")
  linkedInUrl   String?    @default("")
  githubUrl     String     @default("")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  repoUrl     String?
  link        String?
  stack       String[]
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}
